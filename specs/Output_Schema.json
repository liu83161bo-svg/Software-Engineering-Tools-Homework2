{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "MedicalQueryAssistantResponse",
  "type": "object",
  "properties": {
    "status": {
      "type": "string",
      "enum": ["success", "refused", "clarification_needed", "error"],
      "description": "Overall response status"
    },
    "answer": {
      "type": "string",
      "maxLength": 2000,
      "description": "Natural language answer if status is success"
    },
    "sources": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "document_id": { "type": "string" },
          "title": { "type": "string" },
          "relevance_score": { "type": "number", "minimum": 0, "maximum": 1 }
        },
        "required": ["document_id", "title"]
      },
      "description": "List of evidence sources used to generate the answer"
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "Model's confidence in the answer (0-1)"
    },
    "requires_human_review": {
      "type": "boolean",
      "description": "True if the response involves a high-risk action that needs physician approval"
    },
    "error_code": {
      "type": "string",
      "enum": [null, "missing_evidence", "invalid_input", "tool_failure", "internal_error"],
      "description": "Error code if status is error"
    },
    "clarification_question": {
      "type": "string",
      "description": "Question to ask the user if status is clarification_needed"
    }
  },
  "required": ["status", "answer", "sources", "confidence"]
}